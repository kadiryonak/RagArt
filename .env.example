# Turkish RAG System Configuration
# Copy this file and rename to .env

# ============================================
# API KEY (Required for deepseek/openai modes)
# ============================================
# Get your DeepSeek API key from: https://platform.deepseek.com/
# Get your OpenAI API key from: https://platform.openai.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# MODEL CONFIGURATION
# ============================================
# Options: 'deepseek', 'openai', 'ollama', 'local'
# - deepseek: Best for Turkish (requires DEEPSEEK_API_KEY)
# - openai: GPT models (requires OPENAI_API_KEY)
# - ollama: Local Ollama server
# - local: Fallback mode, no API needed
MODEL_TYPE=deepseek

# ============================================
# PATHS
# ============================================
DATA_FOLDER=./data
CHROMA_DB_PATH=./chroma_db

# ============================================
# SERVER SETTINGS
# ============================================
HOST=0.0.0.0
PORT=5000
DEBUG=false

# ============================================
# RAG CONFIGURATION (Optional)
# ============================================
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RELEVANCE_THRESHOLD=0.1
TOP_K_DOCUMENTS=5
