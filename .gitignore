models/




# Local Claude Code config / session data
.claude/

# Generated evaluation reports
tests/evaluation/reports/*.md
tests/evaluation/reports/*.json

# But keep frozen reference baselines
!tests/evaluation/baselines/
!tests/evaluation/baselines/*.md
!tests/evaluation/baselines/*.json

# User-uploaded knowledge base files — keep only the sample Wikipedia set.
# Everything new in data/ (PDFs, DOCX, your own JSONs, etc.) stays local.
data/*.pdf
data/*.docx
data/*.md
data/*.markdown
data/*.txt

# Workspace user-uploaded files — same intent, deeper path now
data/workspaces/**/files/*.pdf
data/workspaces/**/files/*.docx
data/workspaces/**/files/*.md
data/workspaces/**/files/*.markdown
data/workspaces/**/files/*.txt

# Workspace runtime state — only the default workspace's structure is
# tracked (sample data + meta), everything else is per-user.
data/workspaces/*/meta.json
!data/workspaces/default/meta.json

# Vector DB binaries — never track these
data/workspaces/*/chroma_db/
data/workspaces/*/qdrant_db/
data/chroma_db/

# Cache DBs (runtime SQLite files)
data/workspaces/*/cache/
cache/

# A/B evaluation history
eval-history/
